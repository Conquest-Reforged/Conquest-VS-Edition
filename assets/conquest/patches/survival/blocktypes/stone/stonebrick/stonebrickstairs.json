[
    {
        "dependsOn": [
            {
                "modid": "bricklayers",
                "invert": true
            }
        ],
        "op": "remove",
        "path": "/textures",
        "file": "game:blocktypes/stone/stonebrick/stonebrickstairs.json",
        "side": "server"
    },
    {
        "file": "game:blocktypes/stone/stonebrick/stonebrickstairs.json",
        "side": "server",
        "op": "add",
        "path": "/texturesByType",
        "value": {
            "@.*-(andesite|basalt|bauxite|chert|chalk|claystone|conglomerate|granite|limestone|peridotite|phyllite|sandstone|shale|slate|suevite|travertine)-.*": {
                "all": {
                    "base": "game:block/stone/brick/{rock}/*"
                }
            },
            "*": {
                "all": { "base": "game:block/stone/brick/{rock}*" }
            }
        }
    }

]
